---
import { ClientRouter } from 'astro:transitions';
import '../styles/global.css';

interface Props {
  title?: string;
}

const { title = 'Portfolio' } = Astro.props;
---

<!DOCTYPE html>
<html lang="ja">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" href="/favicon.ico" sizes="32x32" />
    <meta property="og:title" content="えりすのプロフィール" />
    <meta property="og:description" content="さいよわなジュニアエンジニアです…" />
    <meta property="og:url" content="https://uaaw.dev" />
    <meta property="og:type" content="website" />
    <meta property="og:image" content="https://uaaw.dev/ogp.jpg" />
    <meta property="og:image:width" content="1024" />
    <meta property="og:image:height" content="1024" />
    <meta name="twitter:card" content="summary" />
    <meta name="twitter:title" content="えりすのプロフィール" />
    <meta name="twitter:description" content="さいよわなジュニアエンジニアです…" />
    <meta name="twitter:image" content="https://uaaw.dev/ogp.jpg" />
    <meta name="description" content="さいよわなジュニアエンジニアです…" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Bebas+Neue&family=Roboto:wght@300;400;500&family=Roboto+Mono&display=swap" rel="stylesheet" />
    <title>{title}</title>
    <ClientRouter />
  </head>
  <body>
    <slot />
  </body>
</html>
