<style>
  .section-title {
    font-size: 1.6rem;
    font-weight: 300;
    color: var(--header-color);
    margin-bottom: 2rem;
    letter-spacing: -0.02em;
  }

  .profile-list {
    display: grid;
    gap: 1.5rem;
  }

  .profile-item {
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
  }

  .profile-item dt {
    font-weight: 500;
    font-size: 0.85rem;
    color: var(--light-gray);
  }

  .profile-item dd {
    font-size: 1rem;
    line-height: 1.6;
    color: var(--primary-text);
  }

  @media (min-width: 640px) {
    .profile-item {
      flex-direction: row;
      align-items: baseline;
      gap: 1rem;
    }

    .profile-item dt {
      min-width: 10rem;
      flex-shrink: 0;
    }
  }
</style>
