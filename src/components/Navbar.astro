<style>
  .navbar {
    position: fixed;
    top: 0;
    left: 0;
    width: 100%;
    z-index: 1000;
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 0 2rem;
    height: 56px;
    background: rgba(30, 30, 40, 0.15);
    backdrop-filter: blur(20px);
    -webkit-backdrop-filter: blur(20px);
    border-bottom: 1px solid rgba(255, 255, 255, 0.15);
  }

  .nav-brand {
    font-family: 'Bebas Neue', sans-serif;
    color: #1a1e2e;
    font-size: 1.5rem;
    font-weight: 400;
    text-decoration: none;
    letter-spacing: 0.04em;
  }

  .nav-brand:hover {
    color: #4a5568;
  }

  .nav-favicon {
    width: 24px;
    height: 24px;
    margin-right: 0.5rem;
    vertical-align: middle;
    border-radius: 2px;
  }

  .nav-links {
    display: flex;
    align-items: center;
    gap: 1.5rem;
    list-style: none;
    margin: 0;
    padding: 0;
  }

  .nav-links a {
    color: #3a4060;
    font-size: 0.9rem;
    font-weight: 400;
    text-decoration: none;
    letter-spacing: 0.03em;
    transition: color 0.2s ease;
  }

  .nav-links a:hover {
    color: #1a1e2e;
  }
